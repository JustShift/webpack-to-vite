{
  "name": "@shiftkit/webpack-to-vite",
  "version": "0.1.0",
  "description": "Analyze a Webpack config and map it to a Vite config. AST-based, with actionable warnings.",
  "keywords": [
    "webpack",
    "vite",
    "migration",
    "codemod",
    "config",
    "converter",
    "analyzer",
    "ast"
  ],
  "license": "Apache-2.0",
  "author": "JustShift",
  "homepage": "https://github.com/JustShift/webpack-to-vite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JustShift/webpack-to-vite.git"
  },
  "bugs": {
    "url": "https://github.com/JustShift/webpack-to-vite/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "webpack-to-vite": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
